@model TodoListApp.WebApp.Models.CommentModel
@{
    ViewData["Title"] = "Edit Comment";
}

<h1 class="h3 mb-4">Edit Comment</h1>

<div class="card-panel">
    <form asp-controller="Comment" asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="TaskId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Text" for="Text" class="form-label"></label>
            <textarea asp-for="Text" id="Text" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Text" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="TodoTask" asp-action="Details" asp-route-id="@this.Model.TaskId" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
