@model TodoListApp.WebApp.Models.CommentModel
@{
    ViewData["Title"] = "Delete Comment";
}

<h1 class="h3 mb-4">Delete Comment</h1>

<div class="card-panel">
    <p>Are you sure you want to delete this comment?</p>
    <blockquote class="text-muted">@this.Model.Text</blockquote>
    <form asp-controller="Comment" asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="TaskId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-controller="TodoTask" asp-action="Details" asp-route-id="@this.Model.TaskId" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
