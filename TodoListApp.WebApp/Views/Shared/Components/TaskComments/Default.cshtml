@model IReadOnlyList<TodoListApp.WebApp.Models.CommentModel>
@{
    int taskId = this.ViewBag.TaskId;
}

<div class="card-panel">
    <h2 class="h5">Comments</h2>
    @if (!this.Model.Any())
    {
        <p class="text-muted">No comments yet.</p>
    }
    else
    {
        foreach (var comment in this.Model)
        {
            <div class="comment-card">
                <div class="d-flex justify-content-between">
                    <strong>@comment.AuthorName</strong>
                    <span class="text-muted small">@comment.CreatedDate.ToString("g")</span>
                </div>
                <p class="mb-1">@comment.Text</p>
                <div class="d-flex gap-2">
                    <a class="small" asp-controller="Comment" asp-action="Edit" asp-route-id="@comment.Id" asp-route-taskId="@taskId" asp-route-text="@comment.Text">Edit</a>
                    <a class="small text-danger" asp-controller="Comment" asp-action="Delete" asp-route-id="@comment.Id" asp-route-taskId="@taskId" asp-route-text="@comment.Text">Delete</a>
                </div>
            </div>
        }
    }
    <form asp-controller="Comment" asp-action="Add" method="post" class="mt-3">
        <input type="hidden" name="taskId" value="@taskId" />
        <div class="mb-2">
            <textarea name="text" class="form-control" rows="2" placeholder="Add a comment" maxlength="2000" required></textarea>
        </div>
        <button type="submit" class="btn btn-outline-primary btn-sm">Add Comment</button>
    </form>
</div>
