@{
    ViewData["Title"] = "Check Your Email";
}

<div class="auth-panel card-panel">
    <h1 class="h3 mb-4 text-center">Check your instructions</h1>
    <p>If an account exists for that email address, password recovery instructions have been sent to it.</p>
    @if (this.TempData["ResetPasswordUrl"] is string resetUrl)
    {
        <div class="alert alert-info">
            <strong>No mail server is configured in this environment.</strong>
            Use this link to reset your password:
            <br />
            <a href="@resetUrl">@resetUrl</a>
        </div>
    }
    <p class="text-center mt-3">
        <a asp-controller="Account" asp-action="Login">Back to sign in</a>
    </p>
</div>
