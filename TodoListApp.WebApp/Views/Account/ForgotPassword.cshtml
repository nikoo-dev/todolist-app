@model TodoListApp.WebApp.Models.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-panel card-panel">
    <h1 class="h3 mb-4 text-center">Restore password</h1>
    <p class="text-muted">Enter the email address you used to sign up and we'll send you password recovery instructions.</p>
    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Email" for="Email" class="form-label"></label>
            <input asp-for="Email" id="Email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">Send recovery instructions</button>
    </form>
    <p class="text-center mt-3">
        <a asp-controller="Account" asp-action="Login">Back to sign in</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
