@{
    ViewData["Title"] = "Password Reset";
}

<div class="auth-panel card-panel text-center">
    <h1 class="h3 mb-4">Password reset</h1>
    <p>Your password has been changed. You can now sign in with your new password.</p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">Sign in</a>
</div>
